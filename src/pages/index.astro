---
export const prerender = true

import { getCollection } from 'astro:content'
import DefaultPageLayout from '$/layouts/default.astro'
import PostPreviewList from '$/components/PostPreviewList.astro'

const title = 'Home'
const description = 'Ruben De Raeve — Software engineer, geometric algorithms, CAD software'

const posts = await getCollection('blog')
---
<DefaultPageLayout content={{ title, description }} showPageHeader={false}>
    <section class="hero">
        <h1 class="hero__heading">
            Software engineer crafting <em>geometric algorithms and CAD software</em>, writing about the experience.
        </h1>
        <p class="hero__intro">
            I'm Ruben — a C++ developer at Bricsys in Ghent, Belgium. I work on geometric modeling, computational geometry, and the internals of BricsCAD. Previously I built cutting optimization algorithms and did high-voltage research in Switzerland.
        </p>
    </section>
    <section class="mt-16">
        <PostPreviewList posts={posts.slice(0, 4)} heading="Recent writing"/>
        <div class="flex justify-end py-4">
            <a class="text-sm font-mono text-zinc-500 hover:text-[#4ade80] transition-colors" href="/blog">all posts →</a>
        </div>
    </section>
</DefaultPageLayout>

<style>
    .hero {
        @apply py-12 md:py-20;
    }
    .hero__heading {
        @apply text-3xl md:text-5xl leading-tight font-serif text-white;
    }
    .hero__heading em {
        @apply text-[#4ade80] not-italic;
    }
    .hero__intro {
        @apply mt-6 text-lg text-zinc-400 max-w-2xl leading-relaxed;
    }
</style>
